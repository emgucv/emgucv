<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Emgu.CV.runtime.webassembly</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <!--
      BLAZORWASM causes CvInvokeEntryPoints.cs to use "__Internal" as the
      DllImport library name, so P/Invoke calls resolve into the native code
      that is statically linked into dotnet.native.wasm via NativeFileReference.
    -->
    <DefineConstants>$(DefineConstants);BLAZORWASM</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Link the Emscripten-compiled cvextern bitcode directly into the .NET
      WebAssembly runtime image.  The wasm-tools build pipeline (Emscripten
      3.1.56) will re-link this bitcode when building the final .wasm.
    -->
    <NativeFileReference Include="$(MSBuildThisFileDirectory)..\..\libs\webgl\libcvextern.bc" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Emgu.CV\WebAssembly\Emgu.CV.WebAssembly.csproj" />
  </ItemGroup>

</Project>
