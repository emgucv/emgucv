<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <!--
      Use the same assembly name as the netstandard2.0 Emgu.CV so that all
      the P/Invoke [DllImport] attribute references compile without changes.
    -->
    <AssemblyName>Emgu.CV</AssemblyName>
    <RootNamespace>Emgu.CV</RootNamespace>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <!--
      BLAZORWASM causes:
        CvInvokeEntryPoints.cs  → ExternLibrary = "libcvextern"
        CvInvoke.cs             → skip dynamic DLL loading in static constructor
    -->
    <DefineConstants>$(DefineConstants);UNSAFE_ALLOWED;BLAZORWASM</DefineConstants>
    <EmguCVProjectRoot>$([System.IO.Path]::GetFullPath($(MSBuildThisFileDirectory)..\..\))</EmguCVProjectRoot>
    <OpenCVBinaryDir>$([System.IO.Path]::GetFullPath($(EmguCVProjectRoot)\libs))</OpenCVBinaryDir>
    <!-- No strong-name signing needed for the WASM build -->
    <SignAssembly>false</SignAssembly>
  </PropertyGroup>

  <!-- Same source sets as Emgu.CV.csproj, minus OCR/CUDA which are not
       included in the Emscripten build of libcvextern.bc -->
  <Import Project="..\Emgu.CV.Shared.projitems" Label="Shared" />
  <Import Project="..\..\Emgu.Util\Emgu.Util.projitems" Label="Shared" />
  <Import Project="..\..\Emgu.CV.Contrib\Emgu.CV.Contrib.projitems" Label="Shared" />

  <ItemGroup>
    <PackageReference Include="System.Drawing.Primitives" Version="4.3.0" />
    <PackageReference Include="System.Runtime.InteropServices.RuntimeInformation" Version="4.3.0" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
  </ItemGroup>

</Project>
